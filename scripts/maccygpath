#!/usr/bin/env bash
#
# cygpath wrapper for nxtOSEK running on macOS
# Wine expects Windows-style host paths, and nxtOSEK asks for `cygpath -m -w`.
#

mixed=""
for arg in "$@"; do
    if [[ "$arg" == -* ]]; then
        if [[ "$arg" == *m* ]]; then
            mixed="yes"
        fi
        continue
    fi

    if [[ "$arg" != /* ]]; then
        arg="$(cd "$(dirname "$arg")" && pwd)/$(basename "$arg")"
    fi

    if [[ -n "$mixed" ]]; then
        printf 'Z:%s\n' "$arg"
    else
        win_path="${arg//\//\\}"
        printf 'Z:%s\n' "$win_path"
    fi
done
